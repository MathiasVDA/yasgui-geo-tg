{
  "name": "yasgui-geo-tg",
  "version": "0.0.2",
  "description": "A Yasgui plugin to add a geo tab",
  "keywords": [
    "yasgui",
    "geosparql",
    "sparql",
    "yasr",
    "geo",
    "geometry",
    "ontology"
  ],
  "homepage": "https://github.com/Thib-G/yasgui-geo-tg#readme",
  "bugs": {
    "url": "https://github.com/Thib-G/yasgui-geo-tg/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Thib-G/yasgui-geo-tg.git"
  },
  "license": "MIT",
  "author": "Thibaut Goelff",
  "type": "module",
  "main": "index.js",
  "module": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "default": "./index.js"
    },
    "./dist/*": "./dist/*",
    "./src/*": "./src/*",
    "./package.json": "./package.json"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "src",
    "dist",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "node build.mjs",
    "build:demo": "vite build demo",
    "preview:demo": "vite preview --port 5174",
    "prepublishOnly": "npm run build && npm test",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.7",
    "@zazuko/yasgui": "^4.6.1",
    "esbuild": "^0.28.0",
    "jsdom": "^28.1.0",
    "vite": "8.0.13",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@turf/helpers": "^7.3.5",
    "@turf/simplify": "^7.3.5",
    "betterknown": "^1.2.0",
    "html-to-image": "^1.11.13",
    "leaflet": "^1.9.4",
    "leaflet-draw": "^1.0.4",
    "leaflet.heat": "^0.2.0",
    "leaflet.markercluster": "^1.5.3",
    "proj4": "^2.20.8"
  }
}
